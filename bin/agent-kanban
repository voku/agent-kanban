#!/usr/bin/env php
<?php

declare(strict_types=1);

// When installed as a dependency, Composer's generated vendor/bin proxy
// `include`s this file directly and sets $GLOBALS['_composer_autoload_path']
// to the *consuming* project's vendor/autoload.php — __DIR__ here would
// otherwise resolve to this package's own bin/ directory (through the
// symlink/proxy), which has no vendor/ of its own. Fall back to the local
// vendor/autoload.php when this package is the root project (e.g. running
// tests inside this repository).
if (isset($GLOBALS['_composer_autoload_path'])) {
    $autoloader = $GLOBALS['_composer_autoload_path'];
    unset($GLOBALS['_composer_autoload_path']);
} else {
    $autoloader = __DIR__ . '/../vendor/autoload.php';
}

if (!is_file($autoloader)) {
    fwrite(STDERR, "Could not locate the Composer autoloader.\n");
    exit(1);
}

require $autoloader;

use voku\AgentKanban\Cli\CliApplication;

$rootPath = getcwd();
if ($rootPath === false) {
    fwrite(STDERR, "Could not determine current working directory.\n");
    exit(1);
}

exit((new CliApplication($rootPath))->run($argv));
